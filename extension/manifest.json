{
  "manifest_version": 3,
  "name": "ZeroTrust One - AI Cyber Assistant",
  "version": "2.0.0",
  "description": "Real-time AI-powered web defense, quishing detection, deepfake analysis, and Zero Trust URL profiling.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
